# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.

# Alpaca paper trading (https://app.alpaca.markets)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Anthropic — Claude Sonnet (brain) and Opus (weekly review)
ANTHROPIC_API_KEY=

# News data — use Finnhub (preferred, free tier) or NewsAPI
FINNHUB_API_KEY=
NEWS_API_KEY=

# Optional: Alpha Vantage fallback for OHLCV data
ALPHA_VANTAGE_KEY=
